<Window x:Class="Ari61850Bridge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ArServer - IEC 61850 to Modbus TCP + MQTT Gateway" Height="900" Width="1480"
        MinHeight="760" MinWidth="1180"
        WindowStartupLocation="CenterScreen" Background="{StaticResource Bg}"
        FontFamily="Aptos, Segoe UI Variable Text, Segoe UI, Calibri" Icon="Assets/app-icon.ico">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBox x:Name="RelayIpTextBox" Visibility="Collapsed" Text="{Binding RelayIpAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Compact application bar: command-first, workspace-dominant. -->
        <Grid Grid.Row="0" Margin="0,0,0,10" Height="44">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="25" Height="25" CornerRadius="12" Margin="0,0,12,0" ClipToBounds="True" SnapsToDevicePixels="True">
                    <Image Source="Assets/app-icon.png" Width="25" Height="25" RenderOptions.BitmapScalingMode="HighQuality"/>
                </Border>
                <TextBlock Text="ARServer" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource Ink}" VerticalAlignment="Center"/>
                <Border Width="1" Height="21" Background="{StaticResource Line}" Margin="14,0"/>
                <TextBlock Text="IEC 61850 - Modbus TCP + MQTT Gateway" FontSize="13.2" Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Grid.Column="1" Text="Fast workflow: add IEC61850 IED -> select SCADA tags -> route to Modbus and MQTT" FontSize="12.5" Foreground="{StaticResource Muted}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="📖 Panduan" Style="{StaticResource MiniChipButton}" Click="Help_Click" Margin="0,0,8,0"/>
                <Button Content="ℹ About" Style="{StaticResource MiniChipButton}" Click="About_Click" Margin="0,0,10,0"/>
                <Border Background="#EAF1FF" CornerRadius="16" Padding="12,7">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Runtime" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,0,7,0"/>
                        <TextBlock Text="{Binding RuntimeStatusText}" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource Accent}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- Gateway navigation: Explorer, Modbus, MQTT, Diagnostics. -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border x:Name="WorkflowNavShell" Width="760" Height="42" HorizontalAlignment="Left" Background="#E7ECF5" CornerRadius="21" Padding="4" Effect="{StaticResource SoftShadow}">
                <Grid x:Name="WorkflowNavGrid" ClipToBounds="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="WorkflowPill" Grid.ColumnSpan="4" Width="182" Height="34" HorizontalAlignment="Left" VerticalAlignment="Center" CornerRadius="17" Background="{StaticResource Accent}" RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="WorkflowPillScale" ScaleX="1" ScaleY="1"/>
                                <TranslateTransform x:Name="WorkflowPillTranslate" X="0"/>
                            </TransformGroup>
                        </Border.RenderTransform>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="14" ShadowDepth="3" Opacity="0.18" Color="#2563EB"/>
                        </Border.Effect>
                    </Border>
                    <Button x:Name="NavConnectButton" Grid.Column="0" Content="IEC 61850 Explorer" Tag="0" Click="NavButton_Click" Style="{StaticResource SegmentedNavButton}"/>
                    <Button x:Name="NavRuntimeButton" Grid.Column="1" Content="Modbus Server" Tag="1" Click="NavButton_Click" Style="{StaticResource SegmentedNavButton}"/>
                    <Button x:Name="NavMqttButton" Grid.Column="2" Content="MQTT Topics" Tag="2" Click="NavButton_Click" Style="{StaticResource SegmentedNavButton}"/>
                    <Button x:Name="NavDiagnosticsButton" Grid.Column="3" Content="Diagnostics" Tag="3" Click="NavButton_Click" Style="{StaticResource SegmentedNavButton}"/>
                </Grid>
            </Border>
            <WrapPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Border Background="White" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="15" Padding="10,6" Margin="0,0,8,0">
                    <TextBlock Text="{Binding IecInsightText}" FontSize="12.5" Foreground="{StaticResource Ink}" Height="18"/>
                </Border>
                <Border Background="White" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="15" Padding="10,6" Margin="0,0,8,0">
                    <TextBlock Text="{Binding ModbusEndpointText}" FontSize="12.5" Foreground="{StaticResource Ink}" Height="19"/>
                </Border>
                <Border Background="White" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="15" Padding="10,6" Margin="0,0,10,0">
                    <TextBlock Text="{Binding ModbusTrafficText}" FontSize="12.5" Foreground="{StaticResource Ink}" Height="18"/>
                </Border>
                <Border x:Name="RuntimeToggleShell" Width="190" Height="40" Background="#E5E7EB" CornerRadius="20" Padding="4" VerticalAlignment="Center" Effect="{StaticResource SoftShadow}">
                    <Grid x:Name="RuntimeToggleGrid" ClipToBounds="True">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border x:Name="RuntimeTogglePill" Width="88" Height="32" HorizontalAlignment="Left" VerticalAlignment="Center" CornerRadius="16" Background="{StaticResource Accent}" RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="RuntimeToggleScale" ScaleX="1" ScaleY="1"/>
                                    <TranslateTransform x:Name="RuntimeToggleTranslate" X="0"/>
                                </TransformGroup>
                            </Border.RenderTransform>
                            <Border.Effect><DropShadowEffect BlurRadius="14" ShadowDepth="3" Opacity="0.22" Color="#2563EB"/></Border.Effect>
                        </Border>
                        <Button x:Name="StartRuntimeToggleButton" Grid.Column="0" Content="▶ Start" Click="StartRuntime_Click" Style="{StaticResource RuntimeSegmentButton}" IsEnabled="{Binding IsProjectEditable}"/>
                        <Button x:Name="StopRuntimeToggleButton" Grid.Column="1" Content="■ Stop" Click="StopRuntime_Click" Style="{StaticResource RuntimeSegmentButton}" IsEnabled="{Binding IsRuntimeRunning}"/>
                    </Grid>
                </Border>
            </WrapPanel>
        </Grid>

        <TabControl x:Name="MainTabs" Grid.Row="2" SelectedIndex="0" Style="{StaticResource HiddenTabControl}" SelectionChanged="MainTabs_SelectionChanged" RenderTransformOrigin="0.5,0.5">
            <TabControl.RenderTransform>
                <TranslateTransform x:Name="PageTranslate" Y="0"/>
            </TabControl.RenderTransform>

            <!-- IEC 61850 EXPLORER -->
            <TabItem Header="IEC 61850 Explorer">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="292"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Left vertical IED explorer. This is the navigation context for multi-IED work. -->
                    <Border Grid.Column="0" Grid.Row="0" Grid.RowSpan="2" Style="{StaticResource Card}" Padding="12" Margin="0,0,0,0">
                        <DockPanel>
                            <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border x:Name="RelayActivityDot" Width="9" Height="9" CornerRadius="5" Background="#2563EB" Margin="0,0,8,0"/>
                                    <TextBlock Text="IED Explorer" Style="{StaticResource SectionTitle}" FontSize="15"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="＋ Add IED" Style="{StaticResource MiniChipButton}" Click="AddRelay_Click" ToolTip="Open Add IED Wizard" IsEnabled="{Binding IsProjectEditable}"/>
                            </Grid>

                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding Relays}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="10" Margin="0,0,0,8" CornerRadius="16" MouseLeftButtonUp="RelayCard_MouseLeftButtonUp" Cursor="Hand" SnapsToDevicePixels="True">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="White"/>
                                                        <Setter Property="BorderBrush" Value="#E5E7EB"/>
                                                        <Setter Property="BorderThickness" Value="1"/>
                                                        <Setter Property="Effect" Value="{StaticResource SoftShadow}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                <Setter Property="Background" Value="#F4F8FF"/>
                                                                <Setter Property="BorderBrush" Value="#2563EB"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Row="0" Grid.Column="0" Width="10" Height="10" CornerRadius="5" Background="{Binding ActivityBrush}" Margin="0,4,9,0" ToolTip="Single MMS state LED: blue = connected idle, green flash = MMS activity, red = failed"/>
                                                    <StackPanel Grid.Row="0" Grid.Column="1">
                                                        <TextBlock Text="{Binding DisplayName}" FontSize="12.7" FontWeight="SemiBold" Foreground="{StaticResource Ink}" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding EndpointText}" FontSize="11.8" Foreground="{StaticResource Muted}" Margin="0,2,0,0"/>
                                                        <TextBlock Text="{Binding SummaryText}" FontSize="11.8" Foreground="{StaticResource Muted}" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding RcbSummaryText}" FontSize="11.4" Foreground="{StaticResource Muted}" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                    <WrapPanel Grid.Row="1" Grid.Column="1" Margin="0,9,0,0">
                                                        <Button Content="✎ Edit" Style="{StaticResource MiniChipButton}" Click="EditRelay_Click" Margin="0,0,6,6" IsEnabled="{Binding DataContext.IsProjectEditable, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                        <Button Content="🗑 Delete" Style="{StaticResource MiniChipButton}" Click="DeleteRelay_Click" Margin="0,0,0,6" IsEnabled="{Binding DataContext.IsProjectEditable, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                    </WrapPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <!-- Main workspace: empty state OR selected IED value table. -->
                    <Grid Grid.Column="2" Grid.Row="0" Margin="0,0,0,10">
                        <!-- Premium empty state when no IED has been saved/selected. -->
                        <Border Style="{StaticResource Card}" Padding="0" Visibility="{Binding EmptyExplorerVisibility}" ClipToBounds="True">
                            <Grid>
                                <Image Source="Assets/gateway-hero.png" Stretch="UniformToFill" Opacity="0.88"/>
                                <Rectangle Fill="#F8FAFC" Opacity="0.20"/>
                                <Border Background="#F8FAFC" Opacity="0.88" CornerRadius="22" Padding="22" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="34" MaxWidth="520">
                                    <StackPanel>
                                        <TextBlock Text="Start by adding your first IED" FontSize="26" FontWeight="SemiBold" Foreground="{StaticResource Ink}"/>
                                        <TextBlock Text="Connect a relay by IP, let ArServer discover IEC 61850 MMS objects, pick SCADA-ready signals, then publish a clean Modbus TCP map for FUXA/HMI." TextWrapping="Wrap" FontSize="13.4" Foreground="{StaticResource Muted}" Margin="0,10,0,18"/>
                                        <WrapPanel>
                                            <Button Content="＋ Add IED" Style="{StaticResource PrimaryButton}" Click="AddRelay_Click" Margin="0,0,8,0" IsEnabled="{Binding IsProjectEditable}"/>
                                            <Button Content="📂 Open Project" Style="{StaticResource SoftButton}" Click="LoadProject_Click" Margin="0,0,8,0"/>
                                            <Button Content="📘 Quick Guide" Style="{StaticResource SoftButton}" Click="Help_Click"/>
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Selected IED workspace. Viewing and editing are intentionally separated:
                             this tab is the lightweight runtime IEC61850 view; signal selection and
                             Modbus binding live inside the Add/Edit IED Wizard only. -->
                        <Grid Visibility="{Binding SelectedExplorerVisibility}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Style="{StaticResource Card}" Padding="12" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Vertical">
                                        <TextBlock Text="{Binding ActiveRelayTitle}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Ink}"/>
                                        <TextBlock Text="{Binding ActiveRelaySubtitle}" FontSize="12.5" Foreground="{StaticResource Muted}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                                        <Border Background="#F8FAFC" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="14" Padding="8,5" Margin="0,0,8,0" ToolTip="IEC 61850 MMS polling target in milliseconds. Fastest allowed target is 10 ms.">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="MMS poll" FontSize="12.2" Foreground="{StaticResource Muted}" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                                <TextBox Width="68" MinHeight="28" Padding="9,4" Text="{Binding MmsPollingIntervalMs, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" IsEnabled="{Binding IsProjectEditable}"/>
                                                <TextBlock Text="ms" FontSize="12.2" Foreground="{StaticResource Muted}" Margin="6,0,8,0" VerticalAlignment="Center"/>
                                                <Button Content="Apply" Style="{StaticResource MiniChipButton}" Click="ApplyMmsPollingToMap_Click" IsEnabled="{Binding IsProjectEditable}" Padding="10,4" MinHeight="28"/>
                                                <Border Width="1" Height="18" Background="{StaticResource Line}" Margin="9,0"/>
                                                <CheckBox Content="Fast CB" IsChecked="{Binding FastAcquisitionEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsProjectEditable}" VerticalAlignment="Center" ToolTip="Prioritize breaker position, status, Boolean and protection flags ahead of analog measurements."/>
                                            </StackPanel>
                                        </Border>
                                        <Button Content="✎ Edit IED Wizard" Style="{StaticResource PrimaryButton}" Click="EditActiveRelay_Click" Margin="0,0,8,0" IsEnabled="{Binding IsProjectEditable}"/>
                                        <Button Content="⇢ Open Modbus Server" Style="{StaticResource SoftButton}" Click="OpenModbusServer_Click"/>
                                    </WrapPanel>
                                </Grid>
                            </Border>

                            <Border Grid.Row="1" Style="{StaticResource Card}" Padding="10">
                                <DockPanel>
                                    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Live IEC 61850 Values" FontSize="15.5" FontWeight="SemiBold" Foreground="{StaticResource Ink}"/>
                                            <TextBlock Text="Runtime view only. Use Edit IED Wizard to add/remove signals, filter MMS objects, and update Modbus binding." FontSize="12.2" Foreground="{StaticResource Muted}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="Priority: position → protection → measurement" Foreground="{StaticResource Muted}" FontSize="12.2" VerticalAlignment="Center"/>
                                    </Grid>
                                    <DataGrid ItemsSource="{Binding SignalsView}" IsReadOnly="True" Style="{StaticResource ModernDataGrid}" ScrollViewer.HorizontalScrollBarVisibility="Auto" ToolTip="Select a row and press Ctrl+C to copy it for debugging.">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Priority" Binding="{Binding Category}" Width="85*" MinWidth="74"/>
                                            <DataGridTextColumn Header="LN" Binding="{Binding LogicalNode}" Width="105*" MinWidth="92"/>
                                            <DataGridTextColumn Header="Signal" Binding="{Binding Name}" Width="180*" MinWidth="150"/>
                                            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="100*" MinWidth="78"/>
                                            <DataGridTextColumn Header="Quality" Binding="{Binding Quality}" Width="80*" MinWidth="68"/>
                                            <DataGridTextColumn Header="Time" Binding="{Binding Timestamp, StringFormat=HH:mm:ss}" Width="75*" MinWidth="66"/>
                                            <DataGridTextColumn Header="Mode" Binding="{Binding ReportPlan}" Width="105*" MinWidth="92"/>
                                            <DataGridTextColumn Header="IEC Object" Binding="{Binding ObjectReference}" Width="200*" MinWidth="170"/>
                                            <DataGridTextColumn Header="Type" Binding="{Binding DataType}" Width="75*" MinWidth="64"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </Border>

                        </Grid>
                    </Grid>

                    <!-- Bottom diagnostics: parked at the bottom of the Explorer page, never floating between runtime content. -->
                    <Expander Grid.Column="2" Grid.Row="1" IsExpanded="False" Margin="0,0,0,0" VerticalAlignment="Bottom">
                        <Expander.Header>
                            <TextBlock Text="IEC 61850 Diagnostics" FontSize="13.2" FontWeight="SemiBold"/>
                        </Expander.Header>
                        <Border Style="{StaticResource Card}" Padding="10" Margin="0,8,0,0" Height="165">
                            <DataGrid ItemsSource="{Binding Logs}" IsReadOnly="True" Style="{StaticResource ModernDataGrid}" ToolTip="Select a row and press Ctrl+C to copy it for debugging.">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Time" Binding="{Binding Time, StringFormat=HH:mm:ss.fff}" Width="115"/>
                                    <DataGridTextColumn Header="Level" Binding="{Binding Level}" Width="70"/>
                                    <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="110"/>
                                    <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Expander>


                </Grid>
            </TabItem>

            <!-- MODBUS SERVER -->
            <TabItem Header="Modbus Server">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource Card}" Padding="12" Margin="0,0,0,10">
                        <StackPanel>
                            <WrapPanel VerticalAlignment="Center">
                                <Border x:Name="ModbusActivityDot" Width="9" Height="9" CornerRadius="5" Background="#94A3B8" Margin="0,0,8,0" ToolTip="Modbus master polling activity"/>
                                <TextBlock Text="Gateway" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource Ink}" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding RuntimeStatusText}" FontSize="13" Foreground="{StaticResource Accent}" FontWeight="SemiBold" Margin="0,0,18,0"/>
                                <TextBlock Text="Modbus" FontSize="12.5" Foreground="{StaticResource Muted}" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding ModbusEndpointText}" FontSize="12.5" Foreground="{StaticResource Ink}" Margin="0,0,18,0"/>
                                <TextBlock Text="Traffic" FontSize="12.5" Foreground="{StaticResource Muted}" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding ModbusTrafficText}" FontSize="12.5" Foreground="{StaticResource Ink}" Margin="0,0,18,0"/>
                                <TextBlock Text="MQTT" FontSize="12.5" Foreground="{StaticResource Muted}" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding MqttEndpointText}" FontSize="12.5" Foreground="{StaticResource Ink}" Margin="0,0,18,0"/>
                                <TextBlock Text="{Binding MqttTrafficText}" FontSize="12.5" Foreground="{StaticResource Ink}" Margin="0,0,18,0"/>
                                <TextBlock Text="IEC" FontSize="12.5" Foreground="{StaticResource Muted}" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding IecInsightText}" FontSize="12.5" Foreground="{StaticResource Ink}" Margin="0,0,18,0"/>
                                <TextBlock Text="MMS Poll" FontSize="12.5" Foreground="{StaticResource Muted}" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding MmsPollingText}" FontSize="12.5" Foreground="{StaticResource Ink}" FontWeight="SemiBold" Margin="0,0,18,0"/>
                                <TextBlock Text="Acq" FontSize="12.5" Foreground="{StaticResource Muted}" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding FastAcquisitionText}" FontSize="12.5" Foreground="{StaticResource Ink}" FontWeight="SemiBold"/>
                            </WrapPanel>
                            <WrapPanel Margin="0,10,0,0" VerticalAlignment="Center">
                                <CheckBox Content="Modbus TCP" IsChecked="{Binding EnableModbusTcp, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsProjectEditable}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                <TextBlock Text="{Binding MmsPollingHintText}" Style="{StaticResource Caption}" VerticalAlignment="Center"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource Card}" Padding="10" Margin="0,0,0,10">
                        <DockPanel>
                            <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Published Modbus Map" FontSize="15.5" FontWeight="SemiBold"/>
                                    <TextBlock Text="  •  authoritative published map from all IED sessions · separated DI/IR/HR blocks per IED" Foreground="{StaticResource Muted}" FontSize="12.2" VerticalAlignment="Center"/>
                                </StackPanel>
                                <WrapPanel Grid.Column="1">
                                    <Button Content="− Remove Binding" Style="{StaticResource SoftButton}" Click="RemoveSelectedBinding_Click" Margin="0,0,8,0"/>
                                    <Button Content="✓ Validate" Style="{StaticResource SoftButton}" Click="Validate_Click" Margin="0,0,8,0"/>
                                    <Button Content="💾 Save" Style="{StaticResource PrimaryButton}" Click="SaveProject_Click"/>
                                </WrapPanel>
                            </Grid>
                            <DataGrid ItemsSource="{Binding PublishedModbusBindings}" SelectedItem="{Binding SelectedBinding, Mode=TwoWay}" Style="{StaticResource ModernDataGrid}" ScrollViewer.HorizontalScrollBarVisibility="Auto" ToolTip="Select a row and press Ctrl+C to copy it for debugging.">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Header="Modbus" Binding="{Binding PublishToModbus, UpdateSourceTrigger=PropertyChanged}" Width="58*" MinWidth="56"/>
                                    <DataGridTextColumn Header="IED" Binding="{Binding IedName}" Width="115*" MinWidth="96" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Signal" Binding="{Binding SignalName, UpdateSourceTrigger=PropertyChanged}" Width="165*" MinWidth="150"/>
                                    <DataGridTextColumn Header="Value" Binding="{Binding CurrentValue}" Width="85*" MinWidth="76" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Q" Binding="{Binding Quality}" Width="70*" MinWidth="58" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Age" Binding="{Binding AgeMs}" Width="55*" MinWidth="54" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Area" Binding="{Binding ModbusArea, UpdateSourceTrigger=PropertyChanged}" Width="105*" MinWidth="96"/>
                                    <DataGridTextColumn Header="Addr" Binding="{Binding ModbusAddress, UpdateSourceTrigger=PropertyChanged}" Width="70*" MinWidth="64"/>
                                    <DataGridTextColumn Header="Type" Binding="{Binding ModbusDataType, UpdateSourceTrigger=PropertyChanged}" Width="75*" MinWidth="66"/>
                                    <DataGridTextColumn Header="Unit" Binding="{Binding Unit, UpdateSourceTrigger=PropertyChanged}" Width="60*" MinWidth="56"/>
                                    <DataGridTextColumn Header="Poll ms" Binding="{Binding PollingIntervalMs, UpdateSourceTrigger=PropertyChanged}" Width="72*" MinWidth="66"/>
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="125*" MinWidth="112" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="IEC Reference" Binding="{Binding IecReference}" Width="260*" MinWidth="220" IsReadOnly="True"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <Expander Grid.Row="2" IsExpanded="False">
                        <Expander.Header>
                            <TextBlock Text="Modbus / Runtime Diagnostics" FontSize="13.2" FontWeight="SemiBold"/>
                        </Expander.Header>
                        <Border Style="{StaticResource Card}" Padding="10" Margin="0,8,0,0" Height="170">
                            <DataGrid ItemsSource="{Binding Logs}" IsReadOnly="True" Style="{StaticResource ModernDataGrid}" ToolTip="Select a row and press Ctrl+C to copy it for debugging.">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Time" Binding="{Binding Time, StringFormat=HH:mm:ss.fff}" Width="115"/>
                                    <DataGridTextColumn Header="Level" Binding="{Binding Level}" Width="70"/>
                                    <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="110"/>
                                    <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Expander>
                </Grid>
            </TabItem>

            <!-- MQTT TOPICS -->
            <TabItem Header="MQTT Topics">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource Card}" Padding="14" Margin="0,0,0,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="28" Height="28" CornerRadius="14" Background="#ECFDF5" BorderBrush="#BBF7D0" BorderThickness="1" Margin="0,0,10,0">
                                        <TextBlock Text="MQ" Foreground="#047857" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel>
                                        <TextBlock Text="MQTT Publisher" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Ink}"/>
                                        <TextBlock Text="Route IEC 61850 signals into broker topics independently from the Modbus map." FontSize="12.4" Foreground="{StaticResource Muted}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <WrapPanel Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Border Background="#F8FAFC" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="15" Padding="10,6" Margin="0,0,8,0">
                                    <TextBlock Text="{Binding MqttEndpointText}" FontSize="12.5" Foreground="{StaticResource Ink}"/>
                                </Border>
                                <Border Background="#F8FAFC" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="15" Padding="10,6">
                                    <TextBlock Text="{Binding MqttTrafficText}" FontSize="12.5" Foreground="{StaticResource Ink}"/>
                                </Border>
                            </WrapPanel>

                            <WrapPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,14,0,0" VerticalAlignment="Center">
                                <CheckBox Content="Enable MQTT" IsChecked="{Binding MqttSettings.IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsProjectEditable}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                <TextBlock Text="Broker" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBox Text="{Binding MqttSettings.BrokerHost, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="150" MinHeight="30" Padding="9,5" IsEnabled="{Binding IsProjectEditable}" Margin="0,0,10,0"/>
                                <TextBlock Text="Port" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBox Text="{Binding MqttSettings.BrokerPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="70" MinHeight="30" Padding="9,5" IsEnabled="{Binding IsProjectEditable}" Margin="0,0,10,0"/>
                                <TextBlock Text="Root" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBox Text="{Binding MqttSettings.TopicRoot, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="140" MinHeight="30" Padding="9,5" IsEnabled="{Binding IsProjectEditable}" Margin="0,0,10,0"/>
                                <TextBlock Text="QoS" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBox Text="{Binding MqttSettings.QualityOfService, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="46" MinHeight="30" Padding="9,5" IsEnabled="{Binding IsProjectEditable}" Margin="0,0,12,0"/>
                                <CheckBox Content="Retain" IsChecked="{Binding MqttSettings.RetainLastValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsProjectEditable}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <CheckBox Content="JSON state" IsChecked="{Binding MqttSettings.PublishJsonState, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsProjectEditable}" VerticalAlignment="Center"/>
                            </WrapPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource Card}" Padding="10" Margin="0,0,0,10">
                        <DockPanel>
                            <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Published MQTT Topics" FontSize="15.5" FontWeight="SemiBold"/>
                                    <TextBlock Text="  -  checked rows publish value, quality, status, and optional JSON state" Foreground="{StaticResource Muted}" FontSize="12.2" VerticalAlignment="Center"/>
                                </StackPanel>
                                <WrapPanel Grid.Column="1">
                                    <Button Content="Validate" Style="{StaticResource SoftButton}" Click="Validate_Click" Margin="0,0,8,0"/>
                                    <Button Content="Save" Style="{StaticResource PrimaryButton}" Click="SaveProject_Click"/>
                                </WrapPanel>
                            </Grid>
                            <DataGrid ItemsSource="{Binding PublishedModbusBindings}" SelectedItem="{Binding SelectedBinding, Mode=TwoWay}" Style="{StaticResource ModernDataGrid}" ScrollViewer.HorizontalScrollBarVisibility="Auto" ToolTip="Use MQTT checkbox and optional topic override to route only selected signals to the broker.">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Header="MQTT" Binding="{Binding PublishToMqtt, UpdateSourceTrigger=PropertyChanged}" Width="54*" MinWidth="52"/>
                                    <DataGridTextColumn Header="IED" Binding="{Binding IedName}" Width="115*" MinWidth="96" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Signal" Binding="{Binding SignalName, UpdateSourceTrigger=PropertyChanged}" Width="170*" MinWidth="150"/>
                                    <DataGridTextColumn Header="Topic Tag" Binding="{Binding MqttTopic, UpdateSourceTrigger=PropertyChanged}" Width="170*" MinWidth="150"/>
                                    <DataGridTextColumn Header="Value" Binding="{Binding CurrentValue}" Width="85*" MinWidth="76" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Q" Binding="{Binding Quality}" Width="70*" MinWidth="58" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Poll ms" Binding="{Binding PollingIntervalMs, UpdateSourceTrigger=PropertyChanged}" Width="72*" MinWidth="66"/>
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="130*" MinWidth="116" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="IEC Reference" Binding="{Binding IecReference}" Width="280*" MinWidth="230" IsReadOnly="True"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <Border Grid.Row="2" CornerRadius="14" Background="#F8FAFC" Padding="12,8" BorderBrush="{StaticResource Line}" BorderThickness="1">
                        <TextBlock Text="Topic shape: root / IED / topic-tag / value | quality | status | state. Leave Topic Tag empty to use FUXA tag or signal name." Foreground="{StaticResource Muted}" FontSize="12.4"/>
                    </Border>
                </Grid>
            </TabItem>

            <!-- DIAGNOSTICS -->
            <TabItem Header="Diagnostics">
                <Grid>
                    <Border Style="{StaticResource Card}" Padding="12">
                        <DockPanel>
                            <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Diagnostics &amp; Event Journal" FontSize="15.5" FontWeight="SemiBold"/>
                                    <TextBlock Text="  •  event-based; polling repetition summarized as counters and activity lights" FontSize="12.2" Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="🧹 Clear Logs" Style="{StaticResource SoftButton}" Click="ClearLogs_Click" VerticalAlignment="Center"/>
                            </Grid>
                            <DataGrid ItemsSource="{Binding Logs}" IsReadOnly="True" Style="{StaticResource ModernDataGrid}" ToolTip="Select a row and press Ctrl+C to copy it for debugging.">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Time" Binding="{Binding Time, StringFormat=yyyy-MM-dd HH:mm:ss.fff}" Width="190"/>
                                    <DataGridTextColumn Header="Level" Binding="{Binding Level}" Width="90"/>
                                    <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="140"/>
                                    <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="3" Margin="0,10,0,0" CornerRadius="14" Background="#EEF4FF" Padding="12,8" BorderBrush="#D7E3F7" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <Border Width="9" Height="9" CornerRadius="5" Background="{StaticResource Accent}" VerticalAlignment="Center" Margin="0,0,9,0"/>
                <TextBlock Grid.Column="1" Text="{Binding LastStatusText}" Foreground="{StaticResource Ink}" FontWeight="Medium" FontSize="12.5" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="{Binding LastStatusLevel}" Foreground="{StaticResource Muted}" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" Margin="16,0,0,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
